        "version": "1.0"
    },
    "host": "localhost:8080",
    "basePath": "/",
    "paths": {
        "/metrics": {
            "get": {
                "description": "Get latest health metrics from sensors",
                "consumes": [
                    "application/json"
                ],
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "metrics"
                ],
                "summary": "Get latest metrics",
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "$ref": "#/definitions/handler.MetricsResponse"
                        }
                    },
                    "500": {
                        "description": "Internal Server Error",
                        "schema": {
                            "type": "object",
                            "additionalProperties": {
                                "type": "string"
                            }
                        }
                    }
                }
            }
        }
    },
    "definitions": {
        "handler.MetricsResponse": {
            "type": "object",
            "properties": {
                "chest_expansion": {
                    "type": "number"
                },
                "muscle_activity": {
                    "type": "number"
                },
                "pulse": {
                    "type": "number"
                },
                "temperature": {
                    "type": "number"
                }
            }
        }
    }
}